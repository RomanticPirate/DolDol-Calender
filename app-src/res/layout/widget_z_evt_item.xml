<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@id/widget_evt_item_root"
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:paddingLeft="6.0dip"
    android:paddingRight="6.0dip"
    android:paddingTop="4.0dip"
    android:paddingBottom="4.0dip">
    <FrameLayout
        android:id="@id/widget_evt_bar"
        android:layout_width="3.0dip"
        android:layout_height="28.0dip"
        android:background="#ff5B6AFF"
        android:layout_marginRight="8.0dip" />
    <TextView
        android:id="@id/widget_evt_date"
        android:textSize="10.0sp"
        android:textColor="#ff7C7C8A"
        android:gravity="center"
        android:layout_width="38.0dip"
        android:layout_height="wrap_content"
        android:singleLine="true" />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_marginLeft="6.0dip">
        <TextView
            android:id="@id/widget_evt_title"
            android:textSize="12.0sp"
            android:textColor="#ff1A1A2E"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="end" />
        <TextView
            android:id="@id/widget_evt_meta"
            android:textSize="10.0sp"
            android:textColor="#ff7C7C8A"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
